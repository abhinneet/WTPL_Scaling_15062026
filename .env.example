# MITRA Dashboard Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# This file contains all configuration needed for the MITRA backend to run.
#
# ⚠️  CRITICAL SECURITY NOTES:
#  1. NEVER commit your real .env file to GitHub (it's already in .gitignore)
#  2. Use Google Secret Manager for production secrets
#  3. Generate strong random values for JWT secrets (see instructions below)
#  4. Change all placeholder values before deploying
#
# ═══════════════════════════════════════════════════════════════════════════

# ── ENVIRONMENT & DEPLOYMENT ─────────────────────────────────────────────────
NODE_ENV=production                      # Options: development | production | staging
PORT=8080                                # Port to listen on (Cloud Run sets this)
LOG_LEVEL=info                           # Options: trace | debug | info | warn | error

# ── APP IDENTITY ─────────────────────────────────────────────────────────────
APP_NAME=MITRA Dashboard
APP_BASE_URL=https://mitra-production-core.web.app
ALLOWED_ORIGINS=https://mitra-production-core.web.app,https://mitra-production-core.firebaseapp.com

# ── JWT AUTHENTICATION (REQUIRED) ────────────────────────────────────────────
# 
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# 
# MUST be different from each other. MUST be ≥32 random bytes.
# The server will refuse to boot with weak secrets.
#
JWT_SECRET=5e7719344fdec31ad1adf66ae47e202eb906d29df3b3161fa01cac1951b4884bd072e6df452368169eaab2aca57c9555
JWT_REFRESH_SECRET=2f3158e150ee1ffadea2da58dac812dbc0329ce0d100e93a591b40c0dfdcf0191679d01b637a20e1a7160ac2e61cab48
JWT_EXPIRES_IN=15m                       # JWT token lifetime
JWT_REFRESH_EXPIRES_IN=7d                # Refresh token lifetime

# ── FIREBASE CONFIGURATION ──────────────────────────────────────────────────
# Set these to point to your fresh Firebase project
#
FIREBASE_PROJECT_ID=mitra-production-core
FIREBASE_ADMIN_SDK_PATH=config/secrets/mitra-production-core-firebase-adminsdk-fbsvc-bee0078b3e.json
STORAGE_BUCKET="mitra-production-core.firebasestorage.app"

# ── CLOUD SQL (PostgreSQL - Admin Data Vault) ───────────────────────────────
# 
# The database stores admin/dashboard data only.
# Student telemetry goes to BigQuery.
# 
# OPTION A: Cloud SQL Connector (recommended for production)
CLOUD_SQL_INSTANCE=mitra-production-core:asia-south1:mitra-db
DB_NAME=mitra
DB_USER=mitra_app
DB_PASSWORD=SET_VIA_GOOGLE_SECRET_MANAGER
DB_POOL_MAX=2
DB_POOL_MIN=1
DB_IDLE_TIMEOUT_MS=2000

# OPTION B: Standard TCP Connection (if using Auth Proxy or local Postgres)
# Uncomment if not using Cloud SQL Connector above
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=mitra
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DATABASE_URL=postgresql://mitra:password@localhost:5432/mitra

# Database SSL (required for production)
DB_SSL=true
DB_SSL_INSECURE=false

# ── BIGQUERY (Analytics Engine - Student Telemetry) ──────────────────────────
# 
# High-volume analytics engine for student app telemetry.
# Data flows: Mobile App → Firestore → (Extension) → BigQuery
#
BIGQUERY_PROJECT_ID=mitra-production-core
BIGQUERY_DATASET_ID=mitra_telemetry_production

# ── CLOUD STORAGE (File Uploads) ────────────────────────────────────────────
# 
# Stores AR assets, advertisements, Unity builds
# Leave blank for local disk mode (development only)
#
MAX_AD_FILE_MB=5
MAX_UNITY_FILE_MB=500
LOCAL_UPLOAD_DIR=./uploads               # Used only if STORAGE_BUCKET is blank

# ── EMAIL (Password Reset, Notifications) ───────────────────────────────────
# 
# For Gmail, generate an App Password here:
#   https://myaccount.google.com/apppasswords
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=SET_VIA_GOOGLE_SECRET_MANAGER
SMTP_FROM="MITRA Dashboard <no-reply@mitra.gov.in>"

# ── INITIAL ADMIN SEED (Used only by `npm run seed`) ───────────────────────
# 
# These are used ONLY when you run `npm run seed` for the first time.
# After seeding, these values are not used again.
# The admin password is set via CLI, never stored in this file.
#
SEED_ADMIN_EMAIL=admin@yourdomain.gov.in
SEED_ADMIN_NAME=Master Admin

# ── BEHAVIOR FLAGS ───────────────────────────────────────────────────────────
# 
# Security and operational flags
#
ALLOW_INLINE_SCRIPTS=false              # false for production, true for development
RATE_LIMIT_AUTH_WINDOW_MS=900000        # 15 minutes
RATE_LIMIT_AUTH_MAX=5                   # Max failed logins before lockout
TRUST_PROXY=true                        # Cloud Run is behind a proxy

# ── OPTIONAL MONITORING & DEBUGGING ──────────────────────────────────────────
# 
# Enable query logging (verbose, use in development only)
# DB_QUERY_LOGGING=false

# ── GOOGLE CLOUD (Auto-set by Cloud Run, override only if needed) ────────────
# 
# These are automatically set by Cloud Run in production.
# Override only if you need a different project.
#
# GCP_PROJECT_ID=mitra-production-core
# K_SERVICE=mitra-api (Cloud Run service name)

# ────────────────────────────────────────────────────────────────────────────
# SETUP CHECKLIST
# ────────────────────────────────────────────────────────────────────────────
#
# Before deploying to production:
#
# [ ] Generate JWT secrets using the command above
# [ ] Create Google Secret Manager entries for passwords
# [ ] Update CLOUD_SQL_INSTANCE with your actual instance name
# [ ] Update FIREBASE_PROJECT_ID with your project name
# [ ] Update STORAGE_BUCKET with your bucket name
# [ ] Configure SMTP credentials for email
# [ ] Test database connection locally
# [ ] Test Firebase connection locally
# [ ] Test BigQuery connection locally
# [ ] Never commit this file to GitHub (it's in .gitignore)
#
# ────────────────────────────────────────────────────────────────────────────
